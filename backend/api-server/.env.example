# ============================================================
# CareDose Backend - Environment Configuration
# ============================================================

PORT=3001

# ── Firebase Admin (pick ONE of three options below) ──────────

# OPTION A (Recommended for local dev):
# Download serviceAccountKey.json from Firebase Console:
# Project Settings → Service Accounts → Generate new private key
# Save the file as: backend/api-server/service-account.json
# (this .env does not need any Firebase vars then)

# OPTION B: Paste the full JSON on one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# OPTION C: Individual fields from the service account JSON
# FIREBASE_PROJECT_ID=caredoseai
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@caredoseai.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Twilio (optional, needed for voice call reminders) ────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# TWILIO_WEBHOOK_BASE_URL=https://your-public-url.ngrok.io
